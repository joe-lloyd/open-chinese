generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Word {
  id          String   @id @default(uuid())
  simplified  String   @unique
  traditional String?
  pinyin      String
  definition  String
  hskLevel    Int?
  status      String   @default("Unstudied")
  deckName    String   @default("Default")
  notes       String?
  review      Review?
  history     ReviewHistory[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id               String   @id @default(uuid())
  wordId           String   @unique
  word             Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  intervalMeaning  Float    @default(0.0)
  intervalPinyin   Float    @default(0.0)
  intervalAudio    Float    @default(0.0)
  easeFactor       Float    @default(2.5)
  consecutiveFails Int      @default(0)
  nextReviewDate   DateTime @default(now())
  lastSubskill     String?
  updatedAt        DateTime @updatedAt
}

model ReviewHistory {
  id                String   @id @default(uuid())
  wordId            String
  word              Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  subskill          String
  response          String
  correct           Boolean
  knewPronunciation Boolean?
  knewMeaning       Boolean?
  reviewedAt        DateTime @default(now())
}

model DeckPriority {
  id       String @id @default(uuid())
  deckName String @unique
  priority Int    @default(0)
}

model DailyStats {
  id           String @id @default(uuid())
  date         String
  deckName     String
  newCardsSeen Int    @default(0)

  @@unique([date, deckName])
}
