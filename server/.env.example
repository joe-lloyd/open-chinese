# Database (SQLite file path)
DATABASE_URL="file:./prisma/dev.db"

# Server port (default 3001)
PORT=3001

# --- Auth (leave blank to disable auth in dev) ---

# Google OAuth credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Random string for signing session JWTs — run: openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# Restrict login to a single Gmail address (leave blank to allow any Google account)
ALLOWED_EMAIL=you@gmail.com

# Where the frontend is served (used for post-auth redirect and CORS)
APP_URL=http://localhost:5173

# --- Whisper pronunciation assessment ---
# "api"   = OpenAI Whisper API (requires OPENAI_API_KEY)
# "local" = local whisper.cpp binary
WHISPER_BACKEND=api
OPENAI_API_KEY=
